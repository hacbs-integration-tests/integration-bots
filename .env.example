# Copy to .env and fill in your values. Do not commit .env.

# Google Drive folder IDs (from folder URLs or Drive UI)
TEAM_DEMOS_FOLDER_ID=
PRESENT_FOLDER_ID=
OLD_FOLDER_ID=

# Template file name starts with this (used to find template in Team demos)
# TEMPLATE_NAME_PATTERN=TEMPLATE for Integration Team Sprint

# When present/ and old/ are empty, use this as the last sprint number
# DEFAULT_SPRINT_NUMBER=305

# Path to service account JSON key file (Drive API)
GOOGLE_APPLICATION_CREDENTIALS=

# Use your Google account for Drive instead of service account (avoids 0 MB quota).
# Set to true and run scripts/auth_drive_oauth.py once; see docs/DRIVE_OAUTH_SETUP.md
# DRIVE_USE_OAUTH=true
# GOOGLE_DRIVE_OAUTH_CREDENTIALS=./credentials_drive_oauth.json
# GOOGLE_DRIVE_TOKEN_PATH=./token_drive.json

# LLM for the agent: openai, gemini, or deepseek
# LLM_PROVIDER=openai

# When LLM_PROVIDER=openai: OpenAI API key
OPENAI_API_KEY=

# When LLM_PROVIDER=deepseek: DeepSeek API key (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=

# When LLM_PROVIDER=gemini: Google AI API key (Gemini)
# Use GOOGLE_API_KEY and/or GEMINI_API_KEY (library accepts both)
GOOGLE_API_KEY=
# GEMINI_API_KEY=

# Slack: post new demo link to team channel after creating the demo.
# Option 1 — Incoming webhook (channel is fixed when you create the webhook):
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# Option 2 — Bot token (lets you choose channel): create a Slack app, add chat:write, install to workspace.
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C01234ABCD
